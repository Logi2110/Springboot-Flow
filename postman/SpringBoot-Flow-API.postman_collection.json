                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow 9d — @PostAuthorize — caller owns resource → 200",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic dXNlcjpwYXNzMTIz",
                "description": "user:pass123",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/secure/method-owned?owner=user",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "secure", "method-owned"],
              "query": [
                { "key": "owner", "value": "user" }
              ]
            },
            "description": "FLOW 9d — @PostAuthorize(owner==caller or ROLE_ADMIN).\n\nCredentials: user / pass123. Requesting owner=user (same as caller).\n@PostAuthorize SpEL: returnObject.get('owner') == authentication.name → TRUE → 200\n\nKey insight: the method body ALWAYS runs first; @PostAuthorize checks the return value AFTER."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200 — owner matches caller\", () => pm.response.to.have.status(200));",
