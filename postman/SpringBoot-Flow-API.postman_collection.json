                  "    const json = pm.response.json();",
                  "    pm.expect(json.owner).to.eql('user');",
                  "    pm.expect(json.annotation).to.eql('@PostAuthorize');",
                  "    pm.expect(json.note).to.include('already ran');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow 9d — @PostAuthorize — caller requests other owner → 403",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic dXNlcjpwYXNzMTIz",
                "description": "user:pass123",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/secure/method-owned?owner=admin",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "secure", "method-owned"],
              "query": [
                { "key": "owner", "value": "admin" }
              ]
            },
            "description": "FLOW 9d exception branch — @PostAuthorize denies access.\n\nCredentials: user / pass123 (ROLE_USER). Requesting owner=admin (different from caller).\nMethod body runs, then @PostAuthorize: returnObject.get('owner')='admin' != authentication.name='user' AND no ROLE_ADMIN → 403.\n\nKey insight: method already executed — @PostAuthorize only prevents the caller from seeing the result."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 403 — @PostAuthorize owner mismatch\", () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow 9d — @PostAuthorize — admin requests any owner → 200",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic YWRtaW46YWRtaW4xMjM=",
                "description": "admin:admin123",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/secure/method-owned?owner=user",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "secure", "method-owned"],
              "query": [
                { "key": "owner", "value": "user" }
              ]
            },
            "description": "FLOW 9d admin path — @PostAuthorize hasRole('ADMIN') bypasses owner check.\n\nCredentials: admin / admin123 (ROLE_ADMIN). Requesting owner=user (different from caller).\n@PostAuthorize: owner != admin BUT hasRole('ADMIN') → TRUE → 200."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
