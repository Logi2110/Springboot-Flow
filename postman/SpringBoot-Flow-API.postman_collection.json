  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('user_id')) {",
          "    pm.environment.set('user_id', '1');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Response time < 2000ms\", () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "console.log(`[${pm.request.method}] ${pm.request.url} → ${pm.response.status} (${pm.response.responseTime}ms)`);"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "Spring Boot application base URL",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "description": "Captured from Flow 2 POST response — used in Flow 3 happy path",
      "type": "string"
    }
  ]
