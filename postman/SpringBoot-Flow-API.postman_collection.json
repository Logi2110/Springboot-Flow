    {
      "name": "Exception Paths",
      "description": "Requests that intentionally trigger exception branches to demonstrate exception handler routing.",
      "item": [
        {
          "name": "Flow 3 — Programmatic Guard (invalid id → IllegalArgumentException)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/-1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "-1"]
            },
            "description": "FLOW 3 exception branch — id <= 0 fails the manual guard in controller.\nThrows IllegalArgumentException → caught by handleIllegalArgumentException() in GlobalExceptionHandler.\n\nStack: Filter → Interceptor → AOP → Controller → IllegalArgumentException → handleIllegalArgumentException → Interceptor afterCompletion → Filter"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400\", () => pm.response.to.have.status(400));",
                  "",
                  "pm.test(\"IllegalArgumentException handler response\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql(400);",
                  "    pm.expect(json.message).to.include(\"positive\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow 2 — Bean Validation Failure (@Valid rejection)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"department\": \"This department name is intentionally too long and exceeds the 100 character maximum limit set by @Size\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "FLOW 2 exception branch — @Valid rejects the request before controller method body executes.\nThrows MethodArgumentNotValidException → caught by handleValidationExceptions() in GlobalExceptionHandler.\n\nValidation rules triggered:\n- name: blank (@NotBlank)\n- email: invalid format (@Email)\n- department: exceeds 100 chars (@Size)\n\nStack: Filter → Interceptor → AOP → @Valid fails → MethodArgumentNotValidException → handleValidationExceptions → Interceptor afterCompletion → Filter"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400\", () => pm.response.to.have.status(400));",
                  "",
                  "pm.test(\"Validation handler response\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql(400);",
                  "    pm.expect(json.error).to.include(\"Validation\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
