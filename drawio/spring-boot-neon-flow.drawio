          vertex="1">
          <mxGeometry x="28" y="110" width="164" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg2" parent="1" value="DispatcherServlet"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B6EFF;fontColor=#1B6EFF;fontStyle=1;fontSize=11;"
          vertex="1">
          <mxGeometry x="28" y="146" width="164" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg3" parent="1" value="HandlerMapping"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BC13FE;fontColor=#BC13FE;fontStyle=1;fontSize=11;"
          vertex="1">
          <mxGeometry x="28" y="182" width="164" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg4" parent="1" value="HandlerAdapter + Handler"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;fontColor=#39FF14;fontStyle=1;fontSize=11;"
          vertex="1">
          <mxGeometry x="28" y="218" width="164" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg5" parent="1" value="ViewResolver"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;fontColor=#F7EB07;fontStyle=1;fontSize=11;"
          vertex="1">
          <mxGeometry x="28" y="254" width="164" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg6" parent="1" value="View"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF6A00;fontColor=#FF6A00;fontStyle=1;fontSize=11;"
          vertex="1">
          <mxGeometry x="28" y="290" width="164" height="28" as="geometry" />
        </mxCell>

        <!-- ═══ MAIN FLOW — center column x=260, w=450 ═══ -->

        <!-- [1] Client -->
        <mxCell id="n1" parent="1"
          value="[1] Client — Browser / Postman&#xa;GET /api/users/flow10"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;strokeWidth=1.5;fontColor=#00E7FF;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="80" width="450" height="58" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="n1" target="n2"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#1B6EFF;strokeWidth=1.5;fontColor=#1B6EFF;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="HTTP Request">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [2] DispatcherServlet -->
        <mxCell id="n2" parent="1"
          value="[2] DispatcherServlet — doDispatch()&#xa;Iterates ALL HandlerMapping beans by @Order (lowest value = highest priority)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B6EFF;strokeWidth=1.5;fontColor=#1B6EFF;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="208" width="450" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="n2" target="n3"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#BC13FE;strokeWidth=1.5;fontColor=#BC13FE;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="getHandler(request)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [3] HandlerMapping -->
        <mxCell id="n3" parent="1"
          value="[3] MvcInternalsHandlerMapping  @Order(-1)&#xa;URI = /api/users/flow10  +  method = GET  →  MATCH ✓&#xa;returns  HandlerExecutionChain(CustomMvcHandler)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BC13FE;strokeWidth=1.5;fontColor=#BC13FE;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="342" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="n3" target="n4"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="HandlerExecutionChain(CustomMvcHandler)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [4] HandlerAdapter -->
        <mxCell id="n4" parent="1"
          value="[4] MvcInternalsHandlerAdapter&#xa;supports(handler)  →  handler instanceof CustomMvcHandler  →  TRUE&#xa;handle() called by DispatcherServlet"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="492" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="n4" target="n5"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="CustomMvcHandler.execute(request)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [5] CustomMvcHandler -->
        <mxCell id="n5" parent="1"
          value="[5] CustomMvcHandler.execute()&#xa;Plain POJO — builds  Map&lt;String, Object&gt;  model&#xa;(step descriptions + uri + note)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="642" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="n5" target="n6"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F7EB07;strokeWidth=1.5;fontColor=#F7EB07;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="resolveViewName('flow10-view', locale)   [called explicitly by HandlerAdapter]">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [6] ViewResolver -->
        <mxCell id="n6" parent="1"
          value="[6] MvcInternalsViewResolver  @Order(1)&#xa;viewName equals 'flow10-view'  →  MATCH ✓&#xa;returns  new JsonView(objectMapper)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1.5;fontColor=#F7EB07;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="796" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="n6" target="n7"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#FF6A00;strokeWidth=1.5;fontColor=#FF6A00;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="view.render(model, request, response)   [called explicitly by HandlerAdapter]">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [7] View -->
        <mxCell id="n7" parent="1"
          value="[7] JsonView.render()&#xa;response.setContentType(application/json)&#xa;objectMapper.writeValue(response.getWriter(), model.get(&quot;data&quot;))"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF6A00;strokeWidth=1.5;fontColor=#FF6A00;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="950" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="n7" target="n8"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#00E7FF;strokeWidth=1.5;fontColor=#00E7FF;fontSize=11;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="HTTP 200 — Content-Type: application/json">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- [8] Client response -->
        <mxCell id="n8" parent="1"
          value="[8] Client — receives JSON response&#xa;Pipeline complete ✓"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;strokeWidth=1.5;fontColor=#00E7FF;fontSize=13;"
          vertex="1">
          <mxGeometry x="260" y="1100" width="450" height="58" as="geometry" />
        </mxCell>

        <!-- ═══ RIGHT-SIDE ANNOTATION BOXES ═══ -->

        <mxCell id="ann2" parent="1"
          value="HandlerMapping priority order:&#xa;  @Order(-1)  →  MvcInternalsHandlerMapping   ← FIRST&#xa;  @Order( 0)  →  RequestMappingHandlerMapping&#xa;  @Order( 2)  →  BeanNameUrlHandlerMapping"
          style="text;html=1;align=left;verticalAlign=top;fontColor=#1B6EFF;fontSize=11;strokeColor=#1B6EFF;fillColor=none;dashed=1;rounded=1;"
          vertex="1">
          <mxGeometry x="748" y="200" width="320" height="76" as="geometry" />
        </mxCell>
        <mxCell id="ann2-line" edge="1" parent="1" source="n2" target="ann2"
          style="strokeColor=#1B6EFF;strokeWidth=1;dashed=1;endArrow=open;endFill=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ann3" parent="1"
          value="Returns null for all other URIs.&#xa;DispatcherServlet falls through to the&#xa;next HandlerMapping in the list."
          style="text;html=1;align=left;verticalAlign=top;fontColor=#BC13FE;fontSize=11;strokeColor=#BC13FE;fillColor=none;dashed=1;rounded=1;"
          vertex="1">
          <mxGeometry x="748" y="350" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ann3-line" edge="1" parent="1" source="n3" target="ann3"
          style="strokeColor=#BC13FE;strokeWidth=1;dashed=1;endArrow=open;endFill=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ann4" parent="1"
          value="WHY explicit ViewResolver/View calls?&#xa;ContentNegotiatingViewResolver (auto-configured at&#xa;Ordered.HIGHEST_PRECEDENCE) would forward&#xa;'flow10-view' as a relative URL → 500 error.&#xa;We call them directly, then return null."
          style="text;html=1;align=left;verticalAlign=top;fontColor=#39FF14;fontSize=11;strokeColor=#39FF14;fillColor=none;dashed=1;rounded=1;"
          vertex="1">
          <mxGeometry x="748" y="490" width="320" height="88" as="geometry" />
        </mxCell>
        <mxCell id="ann4-line" edge="1" parent="1" source="n4" target="ann4"
          style="strokeColor=#39FF14;strokeWidth=1;dashed=1;endArrow=open;endFill=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ann6" parent="1"
          value="Returns null for all other view names.&#xa;@Order(1) only matters if DispatcherServlet&#xa;calls it — here we call it directly."
          style="text;html=1;align=left;verticalAlign=top;fontColor=#F7EB07;fontSize=11;strokeColor=#F7EB07;fillColor=none;dashed=1;rounded=1;"
          vertex="1">
          <mxGeometry x="748" y="800" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ann6-line" edge="1" parent="1" source="n6" target="ann6"
          style="strokeColor=#F7EB07;strokeWidth=1;dashed=1;endArrow=open;endFill=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ann7" parent="1"
          value="HandlerAdapter returns null → response committed.&#xa;DispatcherServlet sees no ModelAndView →&#xa;skips its own ViewResolver loop entirely.&#xa;Same pattern as every @RestController."
          style="text;html=1;align=left;verticalAlign=top;fontColor=#FF6A00;fontSize=11;strokeColor=#FF6A00;fillColor=none;dashed=1;rounded=1;"
          vertex="1">
          <mxGeometry x="748" y="955" width="320" height="72" as="geometry" />
        </mxCell>
        <mxCell id="ann7-line" edge="1" parent="1" source="n7" target="ann7"
          style="strokeColor=#FF6A00;strokeWidth=1;dashed=1;endArrow=open;endFill=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="mvc-p2" name="Custom MVC vs @RestController">
    <mxGraphModel dx="1042" dy="626" grid="1" gridSize="10" guides="0" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="1280" background="#000000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Title ── -->
        <mxCell id="c-title" parent="1"
          value="Spring Boot MVC — Custom Pipeline  vs  @RestController"
