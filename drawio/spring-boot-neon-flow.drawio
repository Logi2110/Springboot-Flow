        </mxCell>
        <mxCell id="cl-leg4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;fontColor=#FF007F;fontStyle=1;fontSize=11;shadow=0;" value="@CacheEvict" vertex="1">
          <mxGeometry height="26" width="160" x="20" y="196" as="geometry" />
        </mxCell>
        <mxCell id="cl-leg5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;fontColor=#39FF14;fontStyle=1;fontSize=11;shadow=0;" value="Controller / Service" vertex="1">
          <mxGeometry height="26" width="160" x="20" y="228" as="geometry" />
        </mxCell>

        <!-- Flow 8a/8b: @Cacheable (HIT vs MISS) -->
        <mxCell id="cl-title1" parent="1" style="text;html=1;align=left;fontColor=#F7EB07;fontStyle=1;fontSize=14;strokeColor=none;fillColor=none;" value="Flow 8a / 8b: @Cacheable" vertex="1">
          <mxGeometry height="28" width="260" x="240" y="80" as="geometry" />
        </mxCell>

        <mxCell id="cl-controller" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="[1] Controller&#xa;GET /api/users/cache-demo/{id}&#xa;calls cacheDemoService.getUser(id)" vertex="1">
          <mxGeometry height="70" width="340" x="240" y="120" as="geometry" />
        </mxCell>

        <mxCell id="cl-proxy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=2;fontColor=#F7EB07;fontStyle=0;fontSize=13;shadow=0;" value="[2] Spring AOP Proxy&#xa;intercepts getUser() call&#xa;checks cache 'users' key=#id" vertex="1">
          <mxGeometry height="70" width="340" x="240" y="220" as="geometry" />
        </mxCell>

        <mxCell id="cl-hit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#7986cb;strokeWidth=2;fontColor=#7986cb;fontStyle=0;fontSize=13;shadow=0;" value="[3a] CACHE HIT&#xa;Method body SKIPPED entirely&#xa;Cached value returned (~0ms)&#xa;ℹ Proof: 'MISS' log never appears" vertex="1">
          <mxGeometry height="80" width="300" x="140" y="340" as="geometry" />
        </mxCell>

        <mxCell id="cl-miss" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#5c6bc0;strokeWidth=2;fontColor=#5c6bc0;fontStyle=0;fontSize=13;shadow=0;" value="[3b] CACHE MISS&#xa;getUser() method body runs&#xa;Logs 'CACHE - MISS'&#xa;Simulates 500ms DB call&#xa;Result stored in cache" vertex="1">
          <mxGeometry height="90" width="300" x="560" y="335" as="geometry" />
        </mxCell>

        <mxCell id="cl-return" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="[4] Controller returns HTTP 200&#xa;body.elapsedMs &lt; 100 = HIT&#xa;body.elapsedMs &gt; 400 = MISS" vertex="1">
          <mxGeometry height="70" width="340" x="240" y="470" as="geometry" />
        </mxCell>

        <!-- Edges: @Cacheable flow -->
        <mxCell id="cl-e1" edge="1" parent="1" source="cl-controller" target="cl-proxy" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F7EB07;strokeWidth=1.5;endArrow=block;endFill=1;" value="call">
