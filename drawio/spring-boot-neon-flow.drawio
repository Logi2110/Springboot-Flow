        <mxCell id="R2e" edge="1" parent="1" source="R2" target="R3"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#39FF14;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════ ROW 3  y=430 — HandlerAdapter ════ -->
        <mxCell id="L3" parent="1"
          value="MvcInternalsHandlerAdapter&#xa;supports(CustomMvcHandler)  →  TRUE&#xa;handle() calls execute(), drives steps 4+5 explicitly"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=12;"
          vertex="1">
