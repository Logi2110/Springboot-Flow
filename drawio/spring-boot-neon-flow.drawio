          vertex="1">
          <mxGeometry x="450" y="448" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="R3" parent="1"
          value="RequestMappingHandlerAdapter&#xa;supports(HandlerMethod)  →  TRUE&#xa;handle() resolves @PathVariable, @Valid, @InitBinder…"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=12;"
          vertex="1">
