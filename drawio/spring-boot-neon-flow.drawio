          <mxGeometry x="450" y="598" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="R4" parent="1"
          value="UserController.getUserById(Long id)&#xa;Returns  ResponseEntity&lt;UserResponse&gt;&#xa;(all param resolution complete before call)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1.5;fontColor=#F7EB07;fontSize=12;"
