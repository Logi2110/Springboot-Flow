          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════ ROW 2  y=280 — Handler object ════ -->
        <mxCell id="L2" parent="1"
          value="CustomMvcHandler  (plain POJO)&#xa;No Spring annotations — just execute()&#xa;Stateless — one instance, reused"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=12;"
          vertex="1">
