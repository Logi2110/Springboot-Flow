          <mxGeometry height="54" width="360" x="80" y="640" as="geometry" />
        </mxCell>
        <mxCell id="ev-timeline" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BC13FE;strokeWidth=1;fontColor=#BC13FE;fontStyle=0;fontSize=11;shadow=0;dashed=1;" value="⏱ Log order to observe:&#xa;1. CONTROLLER - EXECUTING          (http-nio-exec-N)&#xa;2. EVENT LISTENER (SYNC) - RECEIVED (http-nio-exec-N) ← blocks HTTP&#xa;3. EVENT LISTENER (SYNC) - DONE     (http-nio-exec-N)&#xa;4. CONTROLLER - RETURNING           (http-nio-exec-N) ← 200 sent&#xa;5. EVENT LISTENER (ASYNC) - RECEIVED (task-N) ← after response&#xa;6. EVENT LISTENER (ASYNC) - DONE     (task-N) ← ~500ms later" vertex="1">
          <mxGeometry height="110" width="390" x="200" y="710" as="geometry" />
