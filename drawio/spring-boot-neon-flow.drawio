        <!-- ════ ROW 4  y=580 — Business Logic ════ -->
        <mxCell id="L4" parent="1"
          value="CustomMvcHandler.execute()&#xa;Returns  Map&lt;String, Object&gt;  model&#xa;(5 step descriptions + uri + note)"
