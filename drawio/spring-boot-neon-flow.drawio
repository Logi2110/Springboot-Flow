          vertex="1">
          <mxGeometry x="450" y="72" width="300" height="34" as="geometry" />
        </mxCell>
        <mxCell id="hdr-right" parent="1"
          value="Standard @RestController&#xa;GET /api/users/{id}"
          style="text;html=1;align=center;strokeColor=#FF007F;fillColor=none;fontColor=#FF007F;fontStyle=1;fontSize=15;rounded=1;"
          vertex="1">
          <mxGeometry x="790" y="64" width="380" height="50" as="geometry" />
