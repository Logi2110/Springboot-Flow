        </mxCell>

        <!-- ════ ROW 1  y=130 — HandlerMapping ════ -->
        <mxCell id="L1" parent="1"
          value="MvcInternalsHandlerMapping  @Order(-1)&#xa;Runs BEFORE RequestMappingHandlerMapping&#xa;URI = /api/users/flow10  →  MATCH ✓"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BC13FE;strokeWidth=1.5;fontColor=#BC13FE;fontSize=12;"
          vertex="1">
          <mxGeometry x="30" y="130" width="380" height="72" as="geometry" />
        </mxCell>
        <mxCell id="C1" parent="1"
          value="[1] HandlerMapping&#xa;Which handler?"
          style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#AAAAAA;fontStyle=1;fontSize=12;"
          vertex="1">
          <mxGeometry x="450" y="148" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="R1" parent="1"
          value="RequestMappingHandlerMapping  @Order(0)&#xa;Default Spring Boot mapping&#xa;/api/users/{id}  @GetMapping  →  MATCH ✓"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BC13FE;strokeWidth=1.5;fontColor=#BC13FE;fontSize=12;"
          vertex="1">
          <mxGeometry x="790" y="130" width="380" height="72" as="geometry" />
