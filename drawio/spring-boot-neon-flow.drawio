        <mxCell id="as5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF8C00;strokeWidth=1.5;fontColor=#FF8C00;fontStyle=0;fontSize=13;shadow=0;" value="[5] AsyncDemoService.runAsync()&#xa;thread = task-N (thread pool)&#xa;runs ~2s, finishes after HTTP response" vertex="1">
