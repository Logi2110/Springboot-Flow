        </mxCell>

        <!-- ════ ROW 5  y=730 — ViewResolver  ⚡ KEY DIFFERENCE ════ -->
        <mxCell id="L5" parent="1"
          value="MvcInternalsViewResolver&#xa;resolveViewName('flow10-view')  →  JsonView&#xa;✅  CALLED  (explicitly by HandlerAdapter)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1.5;fontColor=#F7EB07;fontSize=12;"
          vertex="1">
          <mxGeometry x="30" y="730" width="380" height="72" as="geometry" />
        </mxCell>
        <mxCell id="C5" parent="1"
          value="⚡ KEY DIFFERENCE&#xa;[5] ViewResolver"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;fontColor=#FF1744;fontStyle=1;fontSize=14;"
          vertex="1">
          <mxGeometry x="460" y="742" width="280" height="44" as="geometry" />
        </mxCell>
        <mxCell id="R5" parent="1"
          value="ViewResolver&#xa;❌  BYPASSED — @ResponseBody detected&#xa;HandlerAdapter writes response directly; no view name produced"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#555555;strokeWidth=1.5;fontColor=#555555;fontSize=12;"
          vertex="1">
          <mxGeometry x="790" y="730" width="380" height="72" as="geometry" />
        </mxCell>
        <mxCell id="L5e" edge="1" parent="1" source="L5" target="L6"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF6A00;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="R5e" edge="1" parent="1" source="R5" target="R6"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF8C00;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;flowAnimation=1;"
          value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════ ROW 6  y=880 — Response Writer ════ -->
        <mxCell id="L6" parent="1"
          value="JsonView.render()&#xa;objectMapper.writeValue(response.getWriter(), data)&#xa;Content-Type: application/json"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF6A00;strokeWidth=1.5;fontColor=#FF6A00;fontSize=12;"
          vertex="1">
          <mxGeometry x="30" y="880" width="380" height="72" as="geometry" />
        </mxCell>
        <mxCell id="C6" parent="1"
          value="[6] Response Writer&#xa;Who writes the body?"
          style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#AAAAAA;fontStyle=1;fontSize=12;"
          vertex="1">
          <mxGeometry x="450" y="898" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="R6" parent="1"
          value="MappingJackson2HttpMessageConverter&#xa;Serialises  @ResponseBody  return value via Jackson&#xa;Content-Type: application/json"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF8C00;strokeWidth=1.5;fontColor=#FF8C00;fontSize=12;"
          vertex="1">
          <mxGeometry x="790" y="880" width="380" height="72" as="geometry" />
        </mxCell>

        <!-- ── Bottom result note ── -->
        <mxCell id="result-left" parent="1"
          value="HandlerAdapter returns null&#xa;→ Response already committed"
          style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#888888;fontSize=11;"
          vertex="1">
          <mxGeometry x="30" y="966" width="380" height="36" as="geometry" />
        </mxCell>
        <mxCell id="result-right" parent="1"
          value="HandlerAdapter returns null&#xa;→ Response already committed"
          style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#888888;fontSize=11;"
          vertex="1">
          <mxGeometry x="790" y="966" width="380" height="36" as="geometry" />
        </mxCell>

        <!-- ── Summary row ── -->
        <mxCell id="summary" parent="1"
          value="Both flows deliver  HTTP 200  application/json  — identical result for the client,  completely different internal pipeline."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;fontColor=#00E7FF;fontStyle=1;fontSize=14;"
          vertex="1">
          <mxGeometry x="100" y="1030" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- ── Comparison table note bottom ── -->
        <mxCell id="tbl-note" parent="1"
          value="Custom MVC: 4 Spring interfaces  |  ViewResolver IS called  |  View writes response&#xa;@RestController: 2 Spring interfaces  |  ViewResolver SKIPPED  |  HttpMessageConverter writes response"
          style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#666666;fontSize=12;"
          vertex="1">
          <mxGeometry x="100" y="1094" width="1000" height="44" as="geometry" />
