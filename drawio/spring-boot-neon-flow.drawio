          vertex="1">
          <mxGeometry x="450" y="298" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="R2" parent="1"
          value="HandlerMethod  (wraps @Controller method)&#xa;UserController.getUserById(Long)&#xa;@PathVariable / @Valid resolved by adapter"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=1.5;fontColor=#39FF14;fontSize=12;"
          vertex="1">
