          <mxGeometry height="70" width="380" x="240" y="888" as="geometry" />
        </mxCell>
        <mxCell id="cl-evict-proxy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;strokeWidth=2;fontColor=#FF007F;fontStyle=0;fontSize=13;shadow=0;" value="[2] @CacheEvict proxy&#xa;Removes key from cache 'users'&#xa;allEntries=true: clears ALL&#xa;Next GET = MISS" vertex="1">
          <mxGeometry height="80" width="380" x="240" y="988" as="geometry" />
        </mxCell>
        <mxCell id="cl-evict-e1" edge="1" parent="1" source="cl-evict-ctrl" target="cl-evict-proxy" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF007F;strokeWidth=1.5;endArrow=block;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Key insight annotation -->
        <mxCell id="cl-insight" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1;fontColor=#F7EB07;fontStyle=0;fontSize=11;shadow=0;dashed=1;" value="⏱ Log observation guide:&#xa;MISS: logs 'CACHE - MISS' + ~500ms elapsed&#xa;HIT : NO 'MISS' log line + &lt;100ms elapsed&#xa;PUT : logs '@CachePut' (method always ran)&#xa;EVICT: logs '@CacheEvict' (entry removed)&#xa;&#xa;CacheManager: ConcurrentMapCacheManager (simple, in-memory)&#xa;Cache name: 'users' | Key: #id (SpEL)&#xa;Switch cache.type=redis in production for TTL + clustering" vertex="1">
          <mxGeometry height="140" width="420" x="620" y="628" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="security-layer" name="Security Layer (Layer 7)">
    <mxGraphModel dx="1042" dy="626" grid="1" gridSize="10" guides="0" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1400" background="#000000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="sl-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#00E7FF;fontStyle=1;fontSize=22;shadow=0;" value="Spring Boot -- Security Layer (Layer 7)" vertex="1">
          <mxGeometry height="40" width="520" x="220" y="18" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="sl-leg1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E040FB;fontColor=#E040FB;fontStyle=1;fontSize=11;shadow=0;" value="SecurityFilterChain" vertex="1">
          <mxGeometry height="26" width="165" x="20" y="80" as="geometry" />
        </mxCell>
        <mxCell id="sl-leg2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;fontColor=#00E7FF;fontStyle=1;fontSize=11;shadow=0;" value="@PreAuthorize" vertex="1">
          <mxGeometry height="26" width="165" x="20" y="112" as="geometry" />
        </mxCell>
        <mxCell id="sl-leg3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;fontColor=#FF007F;fontStyle=1;fontSize=11;shadow=0;" value="@PostAuthorize" vertex="1">
          <mxGeometry height="26" width="165" x="20" y="144" as="geometry" />
        </mxCell>
        <mxCell id="sl-leg4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;fontColor=#39FF14;fontStyle=1;fontSize=11;shadow=0;" value="Controller / Service" vertex="1">
          <mxGeometry height="26" width="165" x="20" y="176" as="geometry" />
        </mxCell>

        <!-- SECTION 1: SecurityFilterChain -->
        <mxCell id="sl-sec1-title" parent="1" style="text;html=1;align=left;fontColor=#F7EB07;fontStyle=1;fontSize=14;strokeColor=none;fillColor=none;" value="1. SecurityFilterChain -- URL-level rules" vertex="1">
          <mxGeometry height="28" width="400" x="240" y="75" as="geometry" />
        </mxCell>

        <mxCell id="sl-client" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;strokeWidth=2;fontColor=#00E7FF;fontStyle=0;fontSize=13;shadow=0;" value="Client Request&#xa;GET /api/users/secure/{endpoint}&#xa;Authorization: Basic base64(user:password)" vertex="1">
          <mxGeometry height="70" width="340" x="240" y="118" as="geometry" />
        </mxCell>

        <mxCell id="sl-chain" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E040FB;strokeWidth=2;fontColor=#E040FB;fontStyle=0;fontSize=13;shadow=0;" value="SecurityFilterChain&#xa;1. Validates HTTP Basic credentials (UserDetailsService)&#xa;2. Checks URL-level rule for matched path&#xa;3. Populates SecurityContext with Authentication" vertex="1">
          <mxGeometry height="80" width="340" x="240" y="220" as="geometry" />
        </mxCell>

        <mxCell id="sl-rules" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1;fontColor=#F7EB07;fontStyle=0;fontSize=11;shadow=0;dashed=1;" value="/secure/public     permitAll           200 always&#xa;/secure/user-only  authenticated()     401 if no creds&#xa;/secure/admin-only hasRole(ADMIN)      403 if ROLE_USER&#xa;/secure/method-*   authenticated() + @PreAuthorize" vertex="1">
          <mxGeometry height="80" width="380" x="630" y="220" as="geometry" />
        </mxCell>

        <mxCell id="sl-permit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="Permitted&#xa;LoggingFilter &gt; Interceptor &gt; AOP &gt; Controller" vertex="1">
          <mxGeometry height="60" width="300" x="240" y="340" as="geometry" />
        </mxCell>

        <mxCell id="sl-denied-url" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;strokeWidth=2;fontColor=#FF007F;fontStyle=0;fontSize=13;shadow=0;" value="Denied (URL rule)&#xa;401 Unauthorized (no creds)&#xa;403 Forbidden (wrong role)" vertex="1">
          <mxGeometry height="70" width="300" x="630" y="332" as="geometry" />
        </mxCell>

        <mxCell id="sl-e1" edge="1" parent="1" source="sl-client" target="sl-chain" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E040FB;strokeWidth=1.5;endArrow=block;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e2a" edge="1" parent="1" source="sl-chain" target="sl-permit" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#39FF14;strokeWidth=1.5;endArrow=block;endFill=1;" value="Allowed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e2b" edge="1" parent="1" source="sl-chain" target="sl-denied-url" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF007F;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;" value="Denied">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SECTION 2: @PreAuthorize -->
        <mxCell id="sl-sec2-title" parent="1" style="text;html=1;align=left;fontColor=#F7EB07;fontStyle=1;fontSize=14;strokeColor=none;fillColor=none;" value="2. @PreAuthorize -- method-level BEFORE body runs" vertex="1">
          <mxGeometry height="28" width="450" x="240" y="455" as="geometry" />
        </mxCell>

        <mxCell id="sl-pre-proxy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00E7FF;strokeWidth=2;fontColor=#00E7FF;fontStyle=0;fontSize=13;shadow=0;" value="Spring AOP Proxy intercepts service call&#xa;Evaluates @PreAuthorize SpEL BEFORE method body&#xa;  hasRole('ADMIN') pass or throw AccessDeniedException" vertex="1">
          <mxGeometry height="75" width="340" x="240" y="495" as="geometry" />
        </mxCell>

        <mxCell id="sl-pre-pass" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="SpEL TRUE: method body runs&#xa;200 OK" vertex="1">
          <mxGeometry height="55" width="250" x="140" y="620" as="geometry" />
        </mxCell>

        <mxCell id="sl-pre-fail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;strokeWidth=2;fontColor=#FF007F;fontStyle=0;fontSize=13;shadow=0;" value="SpEL FALSE: AccessDeniedException&#xa;403 Forbidden (method NEVER ran)" vertex="1">
          <mxGeometry height="55" width="300" x="620" y="620" as="geometry" />
        </mxCell>

        <mxCell id="sl-e3" edge="1" parent="1" source="sl-permit" target="sl-pre-proxy" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#00E7FF;strokeWidth=1.5;endArrow=block;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e4a" edge="1" parent="1" source="sl-pre-proxy" target="sl-pre-pass" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#39FF14;strokeWidth=1.5;endArrow=block;endFill=1;" value="TRUE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e4b" edge="1" parent="1" source="sl-pre-proxy" target="sl-pre-fail" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF007F;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;" value="FALSE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SECTION 3: @PostAuthorize -->
        <mxCell id="sl-sec3-title" parent="1" style="text;html=1;align=left;fontColor=#F7EB07;fontStyle=1;fontSize=14;strokeColor=none;fillColor=none;" value="3. @PostAuthorize -- method-level AFTER body runs" vertex="1">
          <mxGeometry height="28" width="450" x="240" y="730" as="geometry" />
        </mxCell>

        <mxCell id="sl-post-method" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="Service method body ALWAYS runs&#xa;Returns data (e.g. {owner: 'user'})" vertex="1">
          <mxGeometry height="60" width="340" x="240" y="772" as="geometry" />
        </mxCell>

        <mxCell id="sl-post-proxy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;strokeWidth=2;fontColor=#FF007F;fontStyle=0;fontSize=13;shadow=0;" value="Spring AOP Proxy evaluates @PostAuthorize SpEL&#xa;  returnObject.get('owner') == authentication.name&#xa;  or hasRole('ADMIN')" vertex="1">
          <mxGeometry height="75" width="340" x="240" y="872" as="geometry" />
        </mxCell>

        <mxCell id="sl-post-pass" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#39FF14;strokeWidth=2;fontColor=#39FF14;fontStyle=0;fontSize=13;shadow=0;" value="SpEL TRUE: caller sees result&#xa;200 OK" vertex="1">
          <mxGeometry height="55" width="250" x="140" y="1000" as="geometry" />
        </mxCell>

        <mxCell id="sl-post-fail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF007F;strokeWidth=2;fontColor=#FF007F;fontStyle=0;fontSize=13;shadow=0;" value="SpEL FALSE: AccessDeniedException&#xa;403 Forbidden (method already ran!)" vertex="1">
          <mxGeometry height="55" width="300" x="610" y="1000" as="geometry" />
        </mxCell>

        <mxCell id="sl-e5" edge="1" parent="1" source="sl-pre-pass" target="sl-post-method" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#39FF14;strokeWidth=1.5;endArrow=block;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e6" edge="1" parent="1" source="sl-post-method" target="sl-post-proxy" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF007F;strokeWidth=1.5;endArrow=block;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e7a" edge="1" parent="1" source="sl-post-proxy" target="sl-post-pass" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#39FF14;strokeWidth=1.5;endArrow=block;endFill=1;" value="TRUE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sl-e7b" edge="1" parent="1" source="sl-post-proxy" target="sl-post-fail" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF007F;strokeWidth=1.5;dashed=1;endArrow=block;endFill=1;" value="FALSE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Demo credentials + URL rules annotation -->
        <mxCell id="sl-insight" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#F7EB07;strokeWidth=1;fontColor=#F7EB07;fontStyle=0;fontSize=11;shadow=0;dashed=1;" value="Demo users (in-memory):&#xa;  user  / pass123  ROLE_USER&#xa;  admin / admin123 ROLE_USER + ROLE_ADMIN&#xa;&#xa;Postman Base64 credentials:&#xa;  user:pass123   Basic dXNlcjpwYXNzMTIz&#xa;  admin:admin123 Basic YWRtaW46YWRtaW4xMjM=&#xa;&#xa;@EnableWebSecurity on SecurityConfig&#xa;@EnableMethodSecurity on SecurityConfig" vertex="1">
          <mxGeometry height="155" width="360" x="630" y="503" as="geometry" />
        </mxCell>

        <!-- Flow 9 endpoints reference -->
        <mxCell id="sl-endpoints" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E040FB;strokeWidth=1;fontColor=#E040FB;fontStyle=0;fontSize=11;shadow=0;dashed=1;" value="Flow 9 endpoints:&#xa;9a GET /api/users/secure/public       permitAll      200&#xa;9b GET /api/users/secure/user-only    authenticated  401/200&#xa;9c GET /api/users/secure/admin-only   hasRole(ADMIN) 403/200&#xa;9d GET /api/users/secure/method-owned @PostAuthorize 403/200" vertex="1">
          <mxGeometry height="100" width="440" x="240" y="1100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
