        <!-- Cache Layer -->
        <mxCell id="cache-layer" value="💾 Cache Layer (@Cacheable / @CachePut / @CacheEvict)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=16;fontStyle=1;startSize=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="1120" height="140" as="geometry" />
        </mxCell>

        <mxCell id="cache-hit" value="💾 @Cacheable HIT&#xa;• Spring intercepts BEFORE method&#xa;• Returns cached value instantly&#xa;• Method body never runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5c6bc0;strokeColor=#3949ab;strokeWidth=2;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="cache-layer">
          <mxGeometry x="100" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-miss" value="💾 @Cacheable MISS&#xa;• Method runs (~500ms DB call)&#xa;• Result stored in cache&#xa;• Next call will be a HIT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7986cb;strokeColor=#3949ab;strokeWidth=2;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="cache-layer">
          <mxGeometry x="320" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-put" value="💾 @CachePut&#xa;• Method ALWAYS runs&#xa;• Updates cache after write&#xa;• Key must match @Cacheable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9fa8da;strokeColor=#3949ab;strokeWidth=2;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="cache-layer">
          <mxGeometry x="540" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-evict" value="💾 @CacheEvict&#xa;• Removes entry from cache&#xa;• allEntries=true: clears all&#xa;• Next GET will be a MISS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5cae9;strokeColor=#3949ab;strokeWidth=2;fontColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="cache-layer">
          <mxGeometry x="760" y="55" width="190" height="65" as="geometry" />
        </mxCell>

