          <mxGeometry x="290" y="40" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Cache Layer -->
        <mxCell id="cache-layer" value="💾 Cache Layer (@Cacheable / @CachePut / @CacheEvict)" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1DE9B6;fontColor=#1DE9B6;fontSize=16;fontStyle=1;startSize=40;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="1120" height="140" as="geometry" />
        </mxCell>

        <mxCell id="cache-hit" value="💾 @Cacheable HIT&#xa;• Spring intercepts BEFORE method&#xa;• Returns cached value instantly&#xa;• Method body never runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1DE9B6;strokeWidth=1.5;fontColor=#1DE9B6;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="cache-layer">
          <mxGeometry x="100" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-miss" value="💾 @Cacheable MISS&#xa;• Method runs (~500ms DB call)&#xa;• Result stored in cache&#xa;• Next call will be a HIT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1DE9B6;strokeWidth=1.5;fontColor=#1DE9B6;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="cache-layer">
          <mxGeometry x="320" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-put" value="💾 @CachePut&#xa;• Method ALWAYS runs&#xa;• Updates cache after write&#xa;• Key must match @Cacheable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1DE9B6;strokeWidth=1.5;fontColor=#1DE9B6;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="cache-layer">
          <mxGeometry x="540" y="55" width="190" height="65" as="geometry" />
        </mxCell>

        <mxCell id="cache-evict" value="💾 @CacheEvict&#xa;• Removes entry from cache&#xa;• allEntries=true: clears all&#xa;• Next GET will be a MISS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1DE9B6;strokeWidth=1.5;fontColor=#1DE9B6;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="cache-layer">
          <mxGeometry x="760" y="55" width="190" height="65" as="geometry" />
        </mxCell>

