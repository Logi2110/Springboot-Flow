        <!-- Security Layer -->
        <mxCell id="security-layer" value="&#x1f512; Security Layer (@EnableWebSecurity / @PreAuthorize / @PostAuthorize)" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;fontColor=#FF1744;fontSize=16;fontStyle=1;startSize=40;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="1160" width="1120" height="160" as="geometry" />
        </mxCell>
        <mxCell id="sec-filter-chain" value="&#x1f512; SecurityFilterChain&#xa;&#x2022; HTTP Basic auth&#xa;&#x2022; URL-level rules&#xa;&#x2022; Runs before LoggingFilter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;strokeWidth=1.5;fontColor=#FF1744;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="security-layer">
          <mxGeometry x="60" y="55" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sec-userdetails" value="&#x1f512; UserDetailsService&#xa;&#x2022; InMemoryUserDetailsManager&#xa;&#x2022; user / admin accounts&#xa;&#x2022; BCryptPasswordEncoder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;strokeWidth=1.5;fontColor=#FF1744;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="security-layer">
          <mxGeometry x="300" y="55" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sec-preauth" value="&#x1f512; @PreAuthorize&#xa;&#x2022; SpEL evaluated BEFORE method&#xa;&#x2022; hasRole('ADMIN') / isAuthenticated()&#xa;&#x2022; 403 if denied (method never runs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;strokeWidth=1.5;fontColor=#FF1744;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="security-layer">
          <mxGeometry x="540" y="55" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sec-postauth" value="&#x1f512; @PostAuthorize&#xa;&#x2022; SpEL evaluated AFTER method&#xa;&#x2022; returnObject.get('owner') == name&#xa;&#x2022; 403 if denied (method already ran)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF1744;strokeWidth=1.5;fontColor=#FF1744;fontSize=11;fontStyle=1;shadow=0;" vertex="1" parent="security-layer">
          <mxGeometry x="810" y="55" width="230" height="80" as="geometry" />
        </mxCell>

