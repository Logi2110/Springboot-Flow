  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set default user_id if not exists",
          "if (!pm.environment.get(\"user_id\")) {",
          "    pm.environment.set(\"user_id\", \"1\");",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test to check response time",
          "pm.test(\"Response time is less than 2000ms\", function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "// Log execution details",
          "console.log(\"Request:\", pm.request.method, pm.request.url.toString());",
          "console.log(\"Response Time:\", pm.response.responseTime + \"ms\");",
          "console.log(\"Status:\", pm.response.status);"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "Base URL for the Spring Boot Flow API",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "description": "User ID for testing individual user operations",
      "type": "string"
    }
  ]
}